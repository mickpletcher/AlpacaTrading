# Trading Toolkit local environment template
# Copy this file to .env and replace example values with your own.
# This file is safe to commit. Your real .env file is ignored by Git.

# Required Alpaca paper trading credentials
ALPACA_API_KEY=replace_with_your_paper_key
ALPACA_SECRET_KEY=replace_with_your_paper_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# Optional mode flag used by rsi_macd_bot/bot.py
# Keep true while testing.
PAPER=true

# Optional settings for Alpaca/alpaca_paper.py bot
ALPACA_BOT_TICKER=SPY
ALPACA_BOT_INTERVAL_SECONDS=60
ALPACA_BOT_QTY=1
ALPACA_BOT_EMA_FAST=9
ALPACA_BOT_EMA_SLOW=21

# Optional safety settings for Alpaca/circuit_breaker.py
CIRCUIT_BREAKER_MAX_CONSECUTIVE_LOSSES=3
CIRCUIT_BREAKER_RATE_LIMIT_RETRIES=4
CIRCUIT_BREAKER_RATE_LIMIT_BASE_DELAY_SECONDS=2
CIRCUIT_BREAKER_RATE_LIMIT_PAUSE_SECONDS=120
CIRCUIT_BREAKER_SERVER_ERROR_PAUSE_SECONDS=300
CIRCUIT_BREAKER_TIMEOUT_SECONDS=15

# Optional external AI key for manual prompt based coaching workflows
# Current journal code generates prompts locally and does not call Anthropic directly.
ANTHROPIC_API_KEY=replace_if_you_use_external_ai